# ─────────────────────────────────────────────────────────────────────────────
# Cahuita's Taste — Booking Agent Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Calendly ─────────────────────────────────────────────────────────────────
# Get from: Calendly → Integrations → Webhooks
# Set webhook URL to: https://your-domain.com/webhook/calendly
CALENDLY_WEBHOOK_SECRET=your-calendly-webhook-secret

# ── PayPal ────────────────────────────────────────────────────────────────────
# Get from: https://developer.paypal.com → My Apps & Credentials
# Use 'sandbox' for testing, 'production' for live
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_BUSINESS_EMAIL=experiencecahuitastaste@gmail.com

# ── Gmail ─────────────────────────────────────────────────────────────────────
# Setup guide: See README.md → Gmail Setup section
# Get from: Google Cloud Console → APIs → Gmail API → OAuth 2.0
GMAIL_CLIENT_ID=your-google-client-id
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_SENDER_EMAIL=experiencecahuitastaste@gmail.com

# ── Notion ────────────────────────────────────────────────────────────────────
# NOTION_TOKEN: Get from https://www.notion.so/my-integrations
# NOTION_DATABASE_ID: See README.md → Notion Setup section
NOTION_TOKEN=secret_your-notion-integration-token
NOTION_DATABASE_ID=your-cooking-class-database-id

# ── Notion Parent Page ────────────────────────────────────────────────────────
# The Cahuita's Taste main page ID in Notion (where the database will live)
# Copy the ID from the URL of your Cahuita's Taste Notion page
NOTION_PARENT_PAGE_ID=your-parent-page-id
